# direnv: auto-provision the dev environment on `cd` into this repo.
# Requires direnv + uv. Run `direnv allow` once to enable.
# Dev-only — the Pi runs the service via systemd, not a shell.
if ! has uv; then
  echo "uv not found — install from https://docs.astral.sh/uv/" >&2
fi

watch_file pyproject.toml uv.lock

# Base deps only (no `hardware` group — those are Pi-only).
uv sync

export VIRTUAL_ENV="$PWD/.venv"
PATH_add "$PWD/.venv/bin"
